from google.colab import drive
drive.mount('/content/drive')

import wfdb
import matplotlib.pyplot as plt
import numpy as np
from scipy.stats import skew, kurtosis

# ID del paciente
patient_id = '3030937'

# Ruta de donde se encuentra la carpeta con la info
base_path = '/content/drive/MyDrive/brugada-huca-12-lead-ecg-recordings-for-the-study-of-brugada-syndrome-1.0.0/files'


# Leer el registro ECG
record = wfdb.rdrecord(f'{base_path}/{patient_id}/{patient_id}')

# Ver información del registro
print("Derivaciones:", record.sig_name)
print("Frecuencia de muestreo:", record.fs, "Hz")

# Extraer una derivación
lead_index =1
ecg = record.p_signal[:, lead_index]

# Eje de tiempo
t = np.arange(len(ecg)) / record.fs

#MEDIDAS ESTADÍSTICAS

suma=0
N=0
dato_desv=0
dato_asim=0
dato_curt=0

#MEDIA

for dato in ecg:
  suma+=dato
  N+=1

media_1= suma/N
media_2= np.mean(ecg)
print(f"Suma total de datos: {suma}")
print(f"Numero de datos: {N}")
print(f"Media manual: {media_1}")
print(f"Media mediante numpy: {media_2}")

# DESVIACION ESTANDAR

for dato in ecg:
  dato_desv+=(dato-media_1)**2

desv_est1= np.sqrt(dato_desv/(N-1))
desv_est2= np.std(ecg)
print(f"Desviacion estandar manual : {desv_est1}")
print(f"Desviacion estandar función: {desv_est2}")

# COEFICIENTE DE VARIACIÓN

coef_var1= desv_est1/media_1
coef_var2= np.std(ecg)/np.mean(ecg)
print(f"Coeficiente de variación manual: {coef_var1}")
print(f"Coeficiente de variaciones funciones:  {coef_var2}")

#ASIMETRÍA

for dato in ecg:
  dato_asim+=(dato-media_1)**3

asim_1= dato_asim/((N-1)*(desv_est1)**3)
asim_2= skew(ecg, bias=False)
print(f"Asimetría manual: {asim_1}")
print(f"Asimetría función: {asim_2}")

#CURTOSIS

for dato in ecg:
  dato_curt +=(dato-media_1)**4

curt_1 = (1/N)*dato_curt/((desv_est1)**4)-3
curt_2 = kurtosis(ecg, bias=False)
print(f"Curtosis manual: {curt_1}")
print(f"Curtosis función: {curt_2}")


# Graficar
plt.figure(figsize=(12,4))
plt.plot(t, ecg)
plt.xlabel("Tiempo (s)")
plt.ylabel("Amplitud (mV)")
plt.title(f"ECG Brugada-HUCA – Paciente {patient_id} – {record.sig_name[lead_index]}")
plt.grid(True)
plt.show()

#HISTOGRAMA
plt.figure(figsize=(12,4))
plt.hist(ecg, bins=50, weights=np.ones(len(ecg)) / len(ecg) * 100)
plt.xlabel("Amplitud (mV)")
plt.ylabel("Frecuencia ()")
plt.title(f"Histograma – Paciente {patient_id} – {record.sig_name[lead_index]}")
plt.grid(True)
plt.show()
